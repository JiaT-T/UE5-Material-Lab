# Visual Studio and IDE state
.vs/
.vscode/
.idea/
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.user
*.userosscache
*.sln.docstates

# Generated project files
*.sln
*.xcodeproj
*.xcworkspace
.vsconfig

# Compiled object files
*.slo
*.lo
*.o
*.obj

# Precompiled headers
*.gch
*.pch

# Compiled dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables and debug symbols
*.exe
*.out
*.app
*.ipa
*.pdb
*.ilk

# Precompiled assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Unreal generated binaries
Binaries/*
Plugins/**/Binaries/*

# Build artifacts
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files.
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Do not ignore icon files in Build.
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Editor-generated files
Saved/*
Plugins/**/Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Editor cache
DerivedDataCache/*
Plugins/**/DerivedDataCache/*

# OS files
.DS_Store
Thumbs.db
